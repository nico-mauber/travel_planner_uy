# Configuracion OAuth para Trip Planner
# Copiar este archivo como secrets.toml y completar con credenciales reales
# de Google Cloud Console para habilitar autenticacion.
# Sin estas credenciales, la app funciona en modo demo (usuario unico).

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "CAMBIAR_POR_UN_STRING_ALEATORIO_SEGURO"

[auth.google]
client_id = "TU_CLIENT_ID.apps.googleusercontent.com"
client_secret = "GOCSPX-TU_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
